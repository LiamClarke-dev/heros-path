{
  "expo": {
    "name": "Hero's Path",
    "slug": "herospath-replit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "herospath",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0A0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.herospath.app",
      "buildNumber": "14",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Hero's Path uses your location to record your journey and show you on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Hero's Path tracks your location in the background so your journey keeps recording when your screen is locked.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "com.herospath.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D0A0B"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-dev-client",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Hero's Path tracks your location in the background so your journey keeps recording when your screen is locked.",
          "locationWhenInUsePermission": "Hero's Path uses your location to record your journey and show you on the map.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5305f825-31e4-4364-a58c-87862f33e5b5"
      }
    },
    "owner": "liamclarke-dev"
  }
}
